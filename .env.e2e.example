# E2E Test Environment Variables
# Copy this file to .env.e2e and fill in your values:
#   cp .env.e2e.example .env.e2e
#
# Create a test bot: Telegram → @BotFather → /newbot
# Get chat ID: curl https://api.telegram.org/bot<TOKEN>/getUpdates

E2E_TELEGRAM_BOT_TOKEN=
E2E_TELEGRAM_CHAT_ID=

# ─── Real-Bank E2E Suite (opt-in, never runs in CI) ────────────────────
# Run with:  npm run test:e2e:real
#
# Gate flag (suite skips entirely when unset/false)
RUN_REAL_BANK_TESTS=false

# PayBox — phone may be 972XXXXXXXXX or +972XXXXXXXXX, importer normalises
PAYBOX_PHONE_NUMBER=
PAYBOX_OTP_LONG_TERM=

# Pepper — phone may be 972XXXXXXXXX or +972XXXXXXXXX, importer normalises
PEPPER_PHONE_NUMBER=
PEPPER_PASSWORD=
PEPPER_OTP_LONG_TERM=

# OneZero — regression: proves normalisation does not break OneZero login
ONEZERO_EMAIL=
ONEZERO_PASSWORD=
ONEZERO_PHONE_NUMBER=
ONEZERO_OTP_LONG_TERM=
