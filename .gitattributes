# Shell scripts must keep LF line endings so Linux Docker builds succeed
# on Windows contributors (where core.autocrlf=true otherwise converts them).
*.sh text eol=lf

# Husky hook scripts
.husky/* text eol=lf

# Dockerfile must stay LF so RUN layers parse on Linux.
Dockerfile text eol=lf

# Generated portal JSON Schema is written with LF; pin it so the
# schema:check drift gate stays stable on Windows (core.autocrlf=true).
config/portal/config.schema.json text eol=lf
