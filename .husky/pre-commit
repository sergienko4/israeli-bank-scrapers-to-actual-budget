#!/usr/bin/env sh

# Prevent MSYS from converting Unix paths to Windows paths for Docker volume mounts
export MSYS_NO_PATHCONV=1

echo ""
echo "🛑 MANDATORY QUALITY GATE INITIATED 🛑"
echo "==========================================="

# ── 1. Type Safety ──────────────────────────────────────────────
echo ""
echo "🔍 [1/13] Type-checking TypeScript..."
npm run type-check || exit 1

# ── 2. Dependency Audit ─────────────────────────────────────────
echo ""
echo "🔒 [2/13] Auditing dependencies..."
npm audit --audit-level=moderate || exit 1

# ── 3. TypeScript Build ──────────────────────────────────────────
echo ""
echo "🏗️  [3/13] Compiling TypeScript..."
npm run build || exit 1

# ── 4. TypeDoc API Docs ──────────────────────────────────────────
echo ""
echo "📚 [4/13] Generating TypeDoc API docs..."
npm run docs || exit 1

# ── 5. Unit Tests + Coverage ────────────────────────────────────
echo ""
echo "🧪 [5/13] Running unit tests + coverage..."
npm run test:unit || exit 1

# ── 6. ESLint (full src) ────────────────────────────────────────
echo ""
echo "🧹 [6/13] Running ESLint..."
npm run lint || exit 1

# ── 7. Markdown Lint ────────────────────────────────────────────
echo ""
echo "📝 [7/13] Linting markdown docs..."
npm run lint:docs || exit 1

# ── 8. Config Structure ─────────────────────────────────────────
echo ""
echo "⚙️  [8/13] Checking config structure..."
npm run lint:config-structure || exit 1

# ── 9. Docker Build ─────────────────────────────────────────────
echo ""
echo "🐳 [9/13] Building Docker image..."
LOCAL_IMAGE="israeli-bank-importer:pre-commit"
docker build -t "$LOCAL_IMAGE" . || exit 1

# ── 10. Lychee Link Check (via Docker) ──────────────────────────
echo ""
echo "🔗 [10/13] Checking markdown links (lychee)..."
docker run --rm \
  -v "$(pwd):/data" \
  --workdir /data \
  -e GITHUB_TOKEN="${GITHUB_TOKEN:-}" \
  lycheeverse/lychee \
  --exclude-path config/lychee/ignore \
  --exclude-path CHANGELOG.md \
  --no-progress \
  '*.md' 'docs/**/*.md' '.github/**/*.md' || exit 1

# ── 11. Trivy Container Scan ────────────────────────────────────
echo ""
echo "🛡️  [11/13] Scanning Docker image for vulnerabilities (Trivy)..."
docker run --rm \
  -v /var/run/docker.sock:/var/run/docker.sock \
  aquasec/trivy:latest \
  image \
  --exit-code 1 \
  --severity CRITICAL,HIGH \
  --ignore-unfixed \
  --vuln-type os,library \
  --skip-dirs 'root/.npm' \
  "$LOCAL_IMAGE" || exit 1

# ── 12. Mocked E2E Tests (full Docker pipeline — mirrors CI) ────
echo ""
echo "🎭 [12/13] Running mocked E2E tests (Docker pipeline)..."

# Prepare per-bank mock data (mirrors CI step)
mkdir -p tests/e2e/fixtures/mock-scraper-dir
cp tests/e2e/fixtures/mock-scraper-result.json \
  tests/e2e/fixtures/mock-scraper-dir/e2eTestBank.json
cp tests/e2e/fixtures/mock-scraper-result-bank2.json \
  tests/e2e/fixtures/mock-scraper-dir/e2eTestBank2.json

# Create fresh budget
npm run test:e2e:setup || exit 1

# Extract budget ID (mirrors CI step)
BUDGET_ID=$(ls tests/e2e/fixtures/e2e-data/ | grep "e2e-test-budget-" | head -1)
if [ -z "$BUDGET_ID" ]; then
  echo "ERROR: No budget ID found after test:e2e:setup"
  exit 1
fi
echo "Budget ID: $BUDGET_ID"

# Fix node UID ≠ container UID (mirrors CI chmod step)
chmod -R 777 tests/e2e/fixtures/e2e-data

# Run #1: First import (creates transactions)
docker run --rm \
  -v "$(pwd)/tests/e2e/fixtures/config.generated.json:/app/config.json:ro" \
  -v "$(pwd)/tests/e2e/fixtures/mock-scraper-dir:/app/mock-scraper-dir:ro" \
  -v "$(pwd)/tests/e2e/fixtures/e2e-data:/app/data" \
  -e E2E_MOCK_SCRAPER_DIR=/app/mock-scraper-dir \
  -e E2E_LOCAL_BUDGET_ID="$BUDGET_ID" \
  "$LOCAL_IMAGE" node dist/Index.js
DOCKER_EXIT=$?
echo "Run #1 exit code: $DOCKER_EXIT"
if [ $DOCKER_EXIT -gt 1 ]; then
  echo "ERROR: Importer crashed (exit $DOCKER_EXIT)"
  exit 1
fi

# Run #2: Dedup verification (same data → 0 new transactions)
docker run --rm \
  -v "$(pwd)/tests/e2e/fixtures/config.generated.json:/app/config.json:ro" \
  -v "$(pwd)/tests/e2e/fixtures/mock-scraper-dir:/app/mock-scraper-dir:ro" \
  -v "$(pwd)/tests/e2e/fixtures/e2e-data:/app/data" \
  -e E2E_MOCK_SCRAPER_DIR=/app/mock-scraper-dir \
  -e E2E_LOCAL_BUDGET_ID="$BUDGET_ID" \
  "$LOCAL_IMAGE" node dist/Index.js
DOCKER_EXIT=$?
echo "Run #2 exit code: $DOCKER_EXIT"
if [ $DOCKER_EXIT -gt 1 ]; then
  echo "ERROR: Importer crashed (exit $DOCKER_EXIT)"
  exit 1
fi

# Verify pipeline results
npm run test:e2e || exit 1

# ── 13. Real E2E Tests (Telegram) ───────────────────────────────
echo ""
echo "🌐 [13/13] Running real E2E tests (Telegram)..."
npm run test:e2e || exit 1

# ────────────────────────────────────────────────────────────────
echo ""
echo "==========================================="
echo "✅ ALL 13 GATES PASSED. COMMITTING."
echo "   (CodeQL — GitHub CI only, no local equivalent)"
echo "==========================================="
