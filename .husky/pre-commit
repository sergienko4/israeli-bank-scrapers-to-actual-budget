#!/usr/bin/env sh

# Prevent MSYS from converting Unix paths to Windows paths for Docker volume mounts
export MSYS_NO_PATHCONV=1

echo ""
echo "🛑 MANDATORY QUALITY GATE INITIATED 🛑"
echo "==========================================="

# ── 1. Type Safety ──────────────────────────────────────────────
echo ""
echo "🔍 [1/13] Type-checking TypeScript..."
npm run type-check || exit 1

# ── 2. Dependency Audit ─────────────────────────────────────────
echo ""
echo "🔒 [2/13] Auditing dependencies..."
npm audit --audit-level=moderate || exit 1

# ── 3. TypeScript Build ──────────────────────────────────────────
echo ""
echo "🏗️  [3/13] Compiling TypeScript..."
npm run build || exit 1

# ── 4. TypeDoc API Docs ──────────────────────────────────────────
echo ""
echo "📚 [4/13] Generating TypeDoc API docs..."
npm run docs || exit 1

# ── 5. Unit Tests + Coverage ────────────────────────────────────
echo ""
echo "🧪 [5/13] Running unit tests + coverage..."
npm run test:unit || exit 1

# ── 6. ESLint (full src) ────────────────────────────────────────
echo ""
echo "🧹 [6/14] Running ESLint..."
npm run lint || exit 1

# ── 6b. Biome (catches what ESLint misses) ─────────────────────
echo ""
echo "🔬 [6b/14] Running Biome lint..."
npm run lint:biome || exit 1

# ── 7. Markdown Lint ────────────────────────────────────────────
echo ""
echo "📝 [7/14] Linting markdown docs..."
npm run lint:docs || exit 1

# ── 8. Config Structure ─────────────────────────────────────────
echo ""
echo "⚙️  [8/14] Checking config structure..."
npm run lint:config-structure || exit 1

# ── 9. Docker Build + Browser Smoke Test ──────────────────────────
echo ""
echo "🐳 [9/14] Building Docker image..."
LOCAL_IMAGE="israeli-bank-importer:pre-commit"
docker build -t "$LOCAL_IMAGE" . || exit 1

echo ""
echo "🌐 [9/14] Browser smoke test (verifying scraper can launch browser)..."
docker run --rm --cap-add SYS_ADMIN "$LOCAL_IMAGE" \
  node --input-type=module -e "
    import { createScraper } from '@sergienko4/israeli-bank-scrapers';
    const s = createScraper({ companyId: 'hapoalim', startDate: new Date() });
    await s.initialize();
    await s.terminate(true);
    console.log('Browser smoke test passed');
  " || exit 1

# ── 10. Lychee Link Check (via Docker) ──────────────────────────
echo ""
echo "🔗 [10/14] Checking markdown links (lychee)..."
docker run --rm \
  -v "$(pwd):/data" \
  --workdir /data \
  -e GITHUB_TOKEN="${GITHUB_TOKEN:-}" \
  lycheeverse/lychee \
  --exclude-path config/lychee/ignore \
  --exclude-path CHANGELOG.md \
  --no-progress \
  '*.md' 'docs/**/*.md' '.github/**/*.md' || exit 1

# ── 11. Trivy Container Scan ────────────────────────────────────
echo ""
echo "🛡️  [11/14] Scanning Docker image for vulnerabilities + secrets (Trivy)..."
docker run --rm \
  -v /var/run/docker.sock:/var/run/docker.sock \
  -v "$(pwd)/config/trivy:/trivy-config" \
  aquasec/trivy:latest \
  image \
  --exit-code 1 \
  --severity CRITICAL,HIGH \
  --ignore-unfixed \
  --scanners vuln,secret \
  --secret-config /trivy-config/secret.yaml \
  --pkg-types os,library \
  --skip-dirs 'root/.npm' \
  "$LOCAL_IMAGE" || exit 1

# ── 12. Mocked E2E Tests ────────────────────────────────────────
echo ""
echo "🎭 [12/14] Running mocked E2E tests..."
npm run test:e2e:mock || exit 1

# ── 13. Real E2E Tests (Telegram) ───────────────────────────────
echo ""
echo "🌐 [13/14] Running real E2E tests (Telegram)..."
npm run test:e2e || exit 1

# ────────────────────────────────────────────────────────────────
echo ""
echo "==========================================="
echo "✅ ALL 14 GATES PASSED. COMMITTING."
echo "   (CodeQL — GitHub CI only, no local equivalent)"
echo "==========================================="
