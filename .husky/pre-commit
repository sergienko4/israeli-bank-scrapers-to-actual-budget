#!/usr/bin/env sh

# Prevent MSYS from converting Unix paths to Windows paths for Docker volume mounts
export MSYS_NO_PATHCONV=1

echo ""
echo "🛑 MANDATORY QUALITY GATE INITIATED 🛑"
echo "==========================================="

# ── Temp directory for parallel gate output ───────────────────────
GATE_DIR=$(mktemp -d)
trap 'rm -rf "$GATE_DIR"' EXIT

# run_gate <id> <label> <command...>
# Runs a gate in the background, captures output and exit code.
run_gate() {
  _id="$1"; _label="$2"; shift 2
  (
    "$@" > "$GATE_DIR/${_id}.log" 2>&1
    echo $? > "$GATE_DIR/${_id}.exit"
  ) &
}

# wait_gates <id1> <id2> ...
# Waits for all listed gates, prints results, exits on first failure.
wait_gates() {
  wait
  _failed=""
  for _id in "$@"; do
    _exit_code=$(cat "$GATE_DIR/${_id}.exit" 2>/dev/null || echo 1)
    if [ "$_exit_code" = "0" ]; then
      echo "  ✅ $_id"
    else
      echo "  ❌ $_id (exit $_exit_code)"
      _failed="${_failed} ${_id}"
    fi
  done
  if [ -n "$_failed" ]; then
    echo ""
    echo "❌ FAILED GATES:${_failed}"
    echo ""
    for _id in $_failed; do
      echo "── Output of $_id ──"
      cat "$GATE_DIR/${_id}.log" 2>/dev/null
      echo ""
    done
    exit 1
  fi
}

# ═══════════════════════════════════════════════════════════════════
# PHASE 1: Independent gates (no dependencies — all parallel)
# ═══════════════════════════════════════════════════════════════════
echo ""
echo "⚡ Phase 1/3: Running 9 independent gates in parallel..."
echo ""

run_gate "1-typecheck"    "Type-checking TypeScript"       npm run type-check
run_gate "2-audit"        "Auditing dependencies"          npm audit --audit-level=moderate
run_gate "3-build"        "Compiling TypeScript"           npm run build
run_gate "6-eslint"       "Running ESLint"                 npm run lint
run_gate "6b-biome"       "Running Biome lint"             npm run lint:biome
run_gate "7-semgrep"      "Running Semgrep security scan"  docker run --rm -v "$(pwd):/data" --workdir /data semgrep/semgrep@sha256:9fb6f44dc162b1e0aada85f072a95141844c61e3bfcedf40b8a46fecf208e986 semgrep scan --config auto --error src/
run_gate "8-markdownlint" "Linting markdown docs"          npm run lint:docs
run_gate "9-configcheck"  "Checking config structure"      npm run lint:config-structure
run_gate "11-lychee"      "Checking markdown links"        docker run --rm -v "$(pwd):/data" --workdir /data -e GITHUB_TOKEN="${GITHUB_TOKEN:-}" lycheeverse/lychee --exclude-path config/lychee/ignore --exclude-path CHANGELOG.md --no-progress '*.md' 'docs/**/*.md' '.github/**/*.md'

wait_gates \
  "1-typecheck" "2-audit" "3-build" \
  "6-eslint" "6b-biome" "7-semgrep" \
  "8-markdownlint" "9-configcheck" "11-lychee"

echo ""
echo "✅ Phase 1 complete (9 gates passed)"

# ═══════════════════════════════════════════════════════════════════
# PHASE 2: Gates that need build output (parallel)
# ═══════════════════════════════════════════════════════════════════
echo ""
echo "⚡ Phase 2/3: Running 4 build-dependent gates in parallel..."
echo ""

run_gate "4-typedoc"      "Generating TypeDoc API docs"    npm run docs
run_gate "5-unittest"     "Running unit tests + coverage"  npm run test:unit
run_gate "13-e2e-mock"    "Running mocked E2E tests"       npm run test:e2e:mock

# Docker build runs in foreground — Phase 3 needs the image variable
echo "  🐳 Building Docker image..."
LOCAL_IMAGE="israeli-bank-importer:pre-commit"
docker build -t "$LOCAL_IMAGE" . > "$GATE_DIR/10-docker-build.log" 2>&1
if [ $? -ne 0 ]; then
  echo "  ❌ 10-docker-build"
  cat "$GATE_DIR/10-docker-build.log"
  exit 1
fi

echo "  🌐 Browser smoke test..."
docker run --rm --cap-add SYS_ADMIN "$LOCAL_IMAGE" \
  node --input-type=module -e "
    import { createScraper } from '@sergienko4/israeli-bank-scrapers';
    const s = createScraper({ companyId: 'hapoalim', startDate: new Date() });
    await s.initialize();
    await s.terminate(true);
    console.log('Browser smoke test passed');
  " > "$GATE_DIR/10-docker-smoke.log" 2>&1
if [ $? -ne 0 ]; then
  echo "  ❌ 10-docker-smoke"
  cat "$GATE_DIR/10-docker-smoke.log"
  exit 1
fi
echo "  ✅ 10-docker"

wait_gates "4-typedoc" "5-unittest" "13-e2e-mock"

echo ""
echo "✅ Phase 2 complete (4 gates passed)"

# ═══════════════════════════════════════════════════════════════════
# PHASE 3: Gates that need Docker image (parallel)
# ═══════════════════════════════════════════════════════════════════
echo ""
echo "⚡ Phase 3/3: Running 2 final gates in parallel..."
echo ""

run_gate "12-trivy" "Scanning Docker image (Trivy)" docker run --rm -v /var/run/docker.sock:/var/run/docker.sock -v "$(pwd)/config/trivy:/trivy-config" aquasec/trivy:latest image --exit-code 1 --severity CRITICAL,HIGH --ignore-unfixed --scanners vuln,secret --secret-config /trivy-config/secret.yaml --pkg-types os,library --skip-dirs 'root/.npm' "$LOCAL_IMAGE"
run_gate "14-e2e-telegram" "Running real E2E tests (Telegram)" npm run test:e2e

wait_gates "12-trivy" "14-e2e-telegram"

echo ""
echo "✅ Phase 3 complete (2 gates passed)"

# ────────────────────────────────────────────────────────────────
echo ""
echo "==========================================="
echo "✅ ALL 15 GATES PASSED. COMMITTING."
echo "   (CodeQL — GitHub CI only, no local equivalent)"
echo "==========================================="
