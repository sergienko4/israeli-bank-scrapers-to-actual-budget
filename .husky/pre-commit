#!/usr/bin/env sh

# Prevent MSYS from converting Unix paths to Windows paths for Docker volume mounts
export MSYS_NO_PATHCONV=1

# Single source of truth: scripts/ci/gates.mjs is the canonical gate registry.
# This hook runs the local-scope gates honoring the requires DAG, in parallel
# where possible. Adding or removing a gate is a one-place change in gates.mjs.
exec node scripts/ci/run-gates.mjs --scope=local --parallel
