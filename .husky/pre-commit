#!/usr/bin/env sh

# Prevent MSYS from converting Unix paths to Windows paths for Docker volume mounts
export MSYS_NO_PATHCONV=1

echo ""
echo "🛑 MANDATORY QUALITY GATE INITIATED 🛑"
echo "==========================================="

# ── 1. Type Safety ──────────────────────────────────────────────
echo ""
echo "🔍 [1/15] Type-checking TypeScript..."
npm run type-check || exit 1

# ── 2. Dependency Audit ─────────────────────────────────────────
echo ""
echo "🔒 [2/15] Auditing dependencies..."
npm audit --audit-level=moderate || exit 1

# ── 3. TypeScript Build ──────────────────────────────────────────
echo ""
echo "🏗️  [3/15] Compiling TypeScript..."
npm run build || exit 1

# ── 4. TypeDoc API Docs ──────────────────────────────────────────
echo ""
echo "📚 [4/15] Generating TypeDoc API docs..."
npm run docs || exit 1

# ── 5. Unit Tests + Coverage ────────────────────────────────────
echo ""
echo "🧪 [5/15] Running unit tests + coverage..."
npm run test:unit || exit 1

# ── 6. ESLint (full src) ────────────────────────────────────────
echo ""
echo "🧹 [6/15] Running ESLint..."
npm run lint || exit 1

# ── 6b. Biome (catches what ESLint misses) ─────────────────────
echo ""
echo "🔬 [6b/15] Running Biome lint..."
npm run lint:biome || exit 1

# ── 7. Semgrep Security Scan (Docker) ────────────────────────────
echo ""
echo "🛡️  [7/15] Running Semgrep security scan..."
docker run --rm \
  -v "$(pwd):/data" \
  --workdir /data \
  semgrep/semgrep@sha256:9fb6f44dc162b1e0aada85f072a95141844c61e3bfcedf40b8a46fecf208e986 \
  semgrep scan \
  --config auto \
  --error \
  src/ || exit 1

# ── 8. Markdown Lint ────────────────────────────────────────────
echo ""
echo "📝 [8/15] Linting markdown docs..."
npm run lint:docs || exit 1

# ── 9. Config Structure ─────────────────────────────────────────
echo ""
echo "⚙️  [9/15] Checking config structure..."
npm run lint:config-structure || exit 1

# ── 10. Docker Build + Browser Smoke Test ──────────────────────────
echo ""
echo "🐳 [10/15] Building Docker image..."
LOCAL_IMAGE="israeli-bank-importer:pre-commit"
docker build -t "$LOCAL_IMAGE" . || exit 1

echo ""
echo "🌐 [10/15] Browser smoke test (verifying scraper can launch browser)..."
docker run --rm --cap-add SYS_ADMIN "$LOCAL_IMAGE" \
  node --input-type=module -e "
    import { createScraper } from '@sergienko4/israeli-bank-scrapers';
    const s = createScraper({ companyId: 'hapoalim', startDate: new Date() });
    await s.initialize();
    await s.terminate(true);
    console.log('Browser smoke test passed');
  " || exit 1

# ── 11. Lychee Link Check (via Docker) ──────────────────────────
echo ""
echo "🔗 [11/15] Checking markdown links (lychee)..."
docker run --rm \
  -v "$(pwd):/data" \
  --workdir /data \
  -e GITHUB_TOKEN="${GITHUB_TOKEN:-}" \
  lycheeverse/lychee \
  --exclude-path config/lychee/ignore \
  --exclude-path CHANGELOG.md \
  --no-progress \
  '*.md' 'docs/**/*.md' '.github/**/*.md' || exit 1

# ── 12. Trivy Container Scan ────────────────────────────────────
echo ""
echo "🛡️  [12/15] Scanning Docker image for vulnerabilities + secrets (Trivy)..."
docker run --rm \
  -v /var/run/docker.sock:/var/run/docker.sock \
  -v "$(pwd)/config/trivy:/trivy-config" \
  aquasec/trivy:latest \
  image \
  --exit-code 1 \
  --severity CRITICAL,HIGH \
  --ignore-unfixed \
  --scanners vuln,secret \
  --secret-config /trivy-config/secret.yaml \
  --pkg-types os,library \
  --skip-dirs 'root/.npm' \
  "$LOCAL_IMAGE" || exit 1

# ── 13. Mocked E2E Tests ────────────────────────────────────────
echo ""
echo "🎭 [13/15] Running mocked E2E tests..."
npm run test:e2e:mock || exit 1

# ── 14. Real E2E Tests (Telegram) ───────────────────────────────
echo ""
echo "🌐 [14/15] Running real E2E tests (Telegram)..."
npm run test:e2e || exit 1

# ────────────────────────────────────────────────────────────────
echo ""
echo "==========================================="
echo "✅ ALL 15 GATES PASSED. COMMITTING."
echo "   (CodeQL — GitHub CI only, no local equivalent)"
echo "==========================================="
