#!/usr/bin/env sh

# Prevent MSYS from converting Unix paths to Windows paths for Docker volume mounts
export MSYS_NO_PATHCONV=1

# ── Commit-stage scope (Testing Diamond) ──────────────────────────
# Heavy acceptance-stage gates run in GitHub CI ONLY, never in this hook:
#   - Docker image build (--no-cache) + scraper-API smoke test
#   - Trivy image scan (depends on the built image)
#   - mocked E2E (test:e2e:mock) + Telegram E2E (test:e2e)
# CI parity is enforced by .github/workflows/pr.yml (build / trivy / e2e
# jobs) and _e2e-suite.yml (test:e2e:setup + test:e2e). Keeping only the
# fast lint/type/static/unit gates locally holds commits to ~1-2 min and
# avoids blocking on the GitHub-rate-limited camoufox fetch in the Docker
# build. See chore(husky) PR moving these gates to CI-only.

echo ""
echo "🛑 MANDATORY QUALITY GATE INITIATED 🛑"
echo "==========================================="

# ── Temp directory for parallel gate output ───────────────────────
GATE_DIR=$(mktemp -d)
trap 'rm -rf "$GATE_DIR"' EXIT

# run_gate <id> <label> <command...>
# Runs a gate in the background, captures output and exit code.
run_gate() {
  _id="$1"; _label="$2"; shift 2
  (
    echo "Running: ${_label}" > "$GATE_DIR/${_id}.log"
    "$@" >> "$GATE_DIR/${_id}.log" 2>&1
    echo $? > "$GATE_DIR/${_id}.exit"
  ) &
}

# wait_gates <id1> <id2> ...
# Waits for all listed gates, prints results, exits on first failure.
wait_gates() {
  wait
  _failed=""
  for _id in "$@"; do
    _exit_code=$(cat "$GATE_DIR/${_id}.exit" 2>/dev/null || echo 1)
    if [ "$_exit_code" = "0" ]; then
      echo "  ✅ $_id"
    else
      echo "  ❌ $_id (exit $_exit_code)"
      _failed="${_failed} ${_id}"
    fi
  done
  if [ -n "$_failed" ]; then
    echo ""
    echo "❌ FAILED GATES:${_failed}"
    echo ""
    for _id in $_failed; do
      echo "── Output of $_id ──"
      cat "$GATE_DIR/${_id}.log" 2>/dev/null
      echo ""
    done
    exit 1
  fi
}

# ═══════════════════════════════════════════════════════════════════
# PHASE 1: Independent gates (no dependencies — all parallel)
# ═══════════════════════════════════════════════════════════════════
echo ""
echo "⚡ Phase 1/2: Running 17 independent gates in parallel..."
echo ""

run_gate "1-typecheck"    "Type-checking TypeScript"       npm run type-check
run_gate "1b-typecheck-e2e" "Type-checking tests/e2e/"     npm run type-check:e2e
run_gate "1c-typecheck-test" "Type-checking tests/"        npm run type-check:test
run_gate "2-audit"        "Auditing dependencies"          npm audit --audit-level=moderate
run_gate "3-build"        "Compiling TypeScript"           npm run build
run_gate "6-eslint"       "Running ESLint"                 npm run lint
run_gate "6b-biome"       "Running Biome lint"             npm run lint:biome
run_gate "7-semgrep"      "Running Semgrep security scan"  docker run --rm -v "$(pwd):/data" --workdir /data semgrep/semgrep@sha256:9fb6f44dc162b1e0aada85f072a95141844c61e3bfcedf40b8a46fecf208e986 semgrep scan --config auto --config .semgrep/ --error src/
run_gate "8-markdownlint" "Linting markdown docs"          npm run lint:docs
run_gate "9-configcheck"  "Checking config structure"      npm run lint:config-structure
run_gate "10-manifest"    "Checking config manifest completeness" npm run lint:manifest
run_gate "10b-schema"     "Validating generated config schema" npm run schema:check
run_gate "11-lychee"      "Checking markdown links"        docker run --rm -v "$(pwd):/data" --workdir /data -e GITHUB_TOKEN="${GITHUB_TOKEN:-}" lycheeverse/lychee@sha256:609d1bea17f053bee6df907017e4eb8a0163e90633a26fce3ce8aaba1a3df443 --config config/lychee/lychee.toml --no-progress '*.md' 'docs/**/*.md' '.github/**/*.md'
run_gate "15-circular"    "Checking for circular deps in src/" npm run lint:circular
run_gate "17-canaries"    "Verifying ESLint canary rules" npm run lint:canaries
run_gate "18-coupling"    "Checking coupling regression"  npm run coupling:check
run_gate "16-pii-check"  "Checking for PII in error messages" bash -c '
  # Catch interpolated PII variables in error/throw/fail messages
  # e.g., `throw new Error(\`got ${otp}\`)` or `fail(\`token: ${token}\`)`
  # Excludes: static field names like "password is missing" or "token format"
  HITS=$(grep -rn "\${password}\|\${token}\|\${otp}\|\${secret}\|\${digits}\|\${creditCard}" src/ --include="*.ts" | grep -i "throw\|Error\|fail(" || true)
  HITS2=$(grep -rn "\${.*proxy.*}" src/ --include="*.ts" | grep -i "logger\|\.info\|\.warn\|\.error" || true)
  HITS3=$(grep -rn "getLogger().info.*\${.*\.merchant\|getLogger().info.*\${.*\.amount\|getLogger().info.*\${.*\.payee\|getLogger().info.*\${.*customerName\|getLogger().info.*\${.*payeeName" src/ --include="*.ts" || true)
  ALL="${HITS}${HITS2}${HITS3}"
  if [ -n "$ALL" ]; then
    echo "PII variable interpolation detected:"
    echo "$ALL"
    exit 1
  fi
  echo "No PII detected in error messages or info logs"
'

wait_gates \
  "1-typecheck" "1b-typecheck-e2e" "1c-typecheck-test" "2-audit" "3-build" \
  "6-eslint" "6b-biome" "7-semgrep" \
  "8-markdownlint" "9-configcheck" "10-manifest" "10b-schema" "11-lychee" \
  "15-circular" "17-canaries" "18-coupling" \
  "16-pii-check"

echo ""
echo "✅ Phase 1 complete (17 gates passed)"

# ═══════════════════════════════════════════════════════════════════
# PHASE 2: Gates that need build output (parallel)
# ═══════════════════════════════════════════════════════════════════
echo ""
echo "⚡ Phase 2/2: Running 2 build-dependent gates in parallel..."
echo ""

run_gate "4-typedoc"      "Generating TypeDoc API docs"    npm run docs
run_gate "5-unittest"     "Running unit tests + coverage"  npm run test:unit

wait_gates "4-typedoc" "5-unittest"

echo ""
echo "✅ Phase 2 complete (2 gates passed)"

# ────────────────────────────────────────────────────────────────
echo ""
echo "==========================================="
echo "✅ ALL 19 GATES PASSED. COMMITTING."
echo "   (Docker build, Trivy, mocked + Telegram E2E, CodeQL —"
echo "    GitHub CI only: .github/workflows/pr.yml + _e2e-suite.yml)"
echo "==========================================="
