{
  "name": "israeli-bank-actual-importer",
  "version": "1.35.0",
  "description": "Import transactions from Israeli banks into Actual Budget",
  "main": "dist/Index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/Index.js",
    "dev": "tsc && node dist/Index.js",
    "test": "vitest run --config config/vitest.config.ts",
    "test:unit": "vitest run --coverage --config config/vitest.config.ts",
    "test:watch": "vitest --config config/vitest.config.ts",
    "test:e2e": "vitest run --config config/vitest.config.e2e.ts",
    "test:e2e:setup": "npx tsx tests/e2e/e2e-setup.ts",
    "test:e2e:mock": "npm run test:e2e:setup && npm run test:e2e",
    "type-check": "tsc --noEmit",
    "validate": "npm run type-check && npm run build && npm test",
    "validate:ci": "npm run type-check && npm run test:unit && npm run lint",
    "validate:all": "npm run type-check && npm run test:unit && npm run test:e2e:mock && npm run lint && npm run lint:docs && npm run lint:config-structure",
    "lint": "eslint src/",
    "lint:biome": "biome lint src/",
    "lint:docs": "markdownlint-cli2 --config config/markdownlint/.markdownlint.jsonc \"README.md\" \".github/**/*.md\"",
    "lint:config-structure": "node config/check-structure.mjs",
    "lint:licenses": "node config/check-licenses.mjs",
    "docs": "typedoc --options config/typedoc.json",
    "audit": "npm audit --audit-level=moderate",
    "audit:fix": "npm audit fix",
    "outdated": "npm outdated",
    "prepare": "husky"
  },
  "dependencies": {
    "@actual-app/api": "^26.2.0",
    "@sergienko4/israeli-bank-scrapers": "^8.0.0",
    "cron-parser": "^5.5.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/plugin-transform-typescript": "^7.28.6",
    "@biomejs/biome": "^2.4.7",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.3.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-jsdoc": "^62.8.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "license-compliance": "^3.0.1",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.21.0",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite-plugin-babel": "^1.5.1",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "author": "Israeli Bank Importer Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sergienko4/israeli-bank-scrapers-to-actual-budget.git"
  },
  "lint-staged": {
    "src/**/*.ts": "eslint"
  },
  "keywords": [
    "actual-budget",
    "israeli-banks",
    "bank-scraper",
    "transaction-import",
    "fintech",
    "personal-finance",
    "budgeting",
    "automation",
    "self-hosted",
    "docker",
    "typescript",
    "telegram-bot",
    "open-banking",
    "israel",
    "camoufox"
  ]
}
