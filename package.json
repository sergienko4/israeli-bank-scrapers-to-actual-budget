{
  "name": "israeli-bank-actual-importer",
  "version": "1.39.1",
  "description": "Import transactions from Israeli banks into Actual Budget",
  "main": "dist/Index.js",
  "type": "module",
  "scripts": {
    "build": "bash config/tsc-strict-src.sh",
    "start": "node dist/Index.js",
    "dev": "tsc && node dist/Index.js",
    "test": "vitest run --config config/vitest.config.ts",
    "test:unit": "vitest run --coverage --config config/vitest.config.ts",
    "test:watch": "vitest --config config/vitest.config.ts",
    "test:e2e": "vitest run --config config/vitest.config.e2e.ts",
    "test:e2e:setup": "npx tsx tests/e2e/e2e-setup.ts",
    "test:e2e:mock": "npm run test:e2e:setup && npm run test:e2e",
    "test:e2e:real": "vitest run --config config/vitest.config.e2e-real.ts",
    "test:e2e:portal": "vitest run --config config/vitest.config.e2e.ts portal",
    "camoufox:install": "npx @hieutran094/camoufox-js fetch",
    "smoke:google-config": "node scripts/google-oauth-smoke.mjs",
    "type-check": "bash config/tsc-strict-src.sh --noEmit",
    "type-check:e2e": "bash config/tsc-strict-src.sh --noEmit --project tsconfig.e2e.json",
    "type-check:test": "bash config/tsc-strict-src.sh --noEmit --project tsconfig.test.json",
    "validate": "npm run type-check && npm run build && npm test",
    "validate:ci": "npm run type-check && npm run type-check:test && npm run test:unit && npm run lint && npm run lint:canaries && npm run lint:circular && npm run coupling:check",
    "validate:all": "npm run type-check && npm run test:unit && npm run test:e2e:mock && npm run lint && npm run lint:canaries && npm run lint:circular && npm run coupling:check && npm run lint:docs && npm run lint:config-structure && npm run lint:manifest",
    "lint": "eslint src/ && npm run lint:portal-js",
    "lint:portal-js": "eslint --config config/eslint.portal-public.mjs \"src/Portal/Public/**/*.js\"",
    "lint:biome": "npx biome lint src/",
    "lint:docs": "markdownlint-cli2 --config config/markdownlint/.markdownlint.jsonc \"README.md\" \".github/**/*.md\"",
    "lint:config-structure": "node config/check-structure.mjs",
    "lint:manifest": "vitest run --config config/vitest.config.ts tests/config/ManifestGate.test.ts",
    "lint:canaries": "node config/check-eslint-canaries.mjs",
    "lint:circular": "node scripts/check-circular.cjs",
    "lint:licenses": "node config/check-licenses.mjs",
    "coupling:report": "node scripts/coupling-scanner.cjs",
    "coupling:check": "node scripts/coupling-scanner.cjs --check",
    "docs": "typedoc --options config/typedoc.json",
    "docs:site": "pip install -r requirements-docs.txt && python -m mkdocs build --strict",
    "docs:serve": "python -m mkdocs serve",
    "meta:render": "node scripts/render-readme-meta.mjs",
    "meta:check": "node scripts/render-readme-meta.mjs --check",
    "meta:markers": "bash scripts/check-readme-markers.sh",
    "audit": "npm audit --audit-level=moderate",
    "audit:fix": "npm audit fix",
    "outdated": "npm outdated",
    "prepare": "husky"
  },
  "dependencies": {
    "@actual-app/api": "^26.7.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^10.1.0",
    "@sergienko4/israeli-bank-scrapers": "^8.6.0",
    "cron-parser": "^5.6.1",
    "fastify": "^5.10.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.35.3",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.5.0",
    "@hieutran094/camoufox-js": "^0.6.8",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-check-file": "^3.3.2",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsdoc": "^63.2.0",
    "eslint-plugin-n": "^18.2.2",
    "eslint-plugin-regexp": "^3.1.1",
    "eslint-plugin-simple-import-sort": "^14.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "license-compliance": "^3.0.1",
    "markdownlint-cli2": "^0.23.0",
    "patch-package": "^8.0.1",
    "playwright-core": "~1.59.1",
    "typedoc": "^0.28.20",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.9",
    "yaml": "^2.5.0"
  },
  "overrides": {
    "smol-toml": ">=1.6.1",
    "uuid": "^14.0.0",
    "postcss": "^8.5.10",
    "joi": "^18.2.1",
    "js-yaml": "^4.3.0",
    "markdown-it": "^14.2.0",
    "adm-zip": "^0.6.0",
    "brace-expansion": "^5.0.7",
    "fast-uri": "^3.1.4",
    "linkify-it": "^5.0.2"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "author": "Israeli Bank Importer Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sergienko4/israeli-bank-scrapers-to-actual-budget.git"
  },
  "keywords": [
    "actual-budget",
    "israeli-banks",
    "bank-scraper",
    "transaction-import",
    "fintech",
    "personal-finance",
    "budgeting",
    "automation",
    "self-hosted",
    "docker",
    "typescript",
    "telegram-bot",
    "open-banking",
    "israel",
    "camoufox"
  ]
}
